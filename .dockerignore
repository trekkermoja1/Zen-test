# =============================================================================
# Docker Ignore - Sicherheitskritische Dateien
# =============================================================================
# Diese Dateien werden NICHT in Docker-Images kopiert
# =============================================================================

# =============================================================================
# Secrets & Credentials
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
credentials/
config/secrets*

# =============================================================================
# Git
# =============================================================================
.git
.gitignore
.gitattributes
.github/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.hypothesis/

# =============================================================================
# Virtual Environments
# =============================================================================
venv/
env/
ENV/
.venv/

# =============================================================================
# IDEs
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# =============================================================================
# Logs & Datenbanken
# =============================================================================
*.log
logs/
*.sqlite
*.sqlite3
*.db

# =============================================================================
# Test Coverage
# =============================================================================
.coverage
htmlcov/
.tox/
.nox/

# =============================================================================
# Dokumentation (im Image nicht nötig)
# =============================================================================
docs/
*.md
!README.md

# =============================================================================
# CI/CD
# =============================================================================
.github/
.gitlab-ci.yml
Jenkinsfile
.travis.yml
appveyor.yml

# =============================================================================
# Docker
# =============================================================================
Dockerfile*
docker-compose*.yml
.docker/

# =============================================================================
# Node.js (Frontend - separat gebaut)
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
web_ui/frontend/node_modules/
web_ui/frontend/build/
web_ui/frontend/.cache/

# =============================================================================
# Kali Linux / Pentesting Tools (werden im Container installiert)
# =============================================================================
tools/kali/
*.iso
*.ova
*.ovf

# =============================================================================
# Backup & Temp Files
# =============================================================================
*.bak
*.tmp
*.temp
*.orig

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
Thumbs.db
