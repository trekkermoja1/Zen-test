# Snyk Security Policy
# https://docs.snyk.io/snyk-cli/commands/ignore

version: v1.25.0
ignore:
  # SNYK-CC-K8S-8: Read-only root filesystem
  # Required for databases to write data
  - SNYK-CC-K8S-8:
    - '*postgres.yaml':
        reason: 'PostgreSQL requires write access to data directory'
        expires: '2025-08-24T00:00:00.000Z'
    - '*redis.yaml':
        reason: 'Redis requires write access to data directory'
        expires: '2025-08-24T00:00:00.000Z'

  # SNYK-CC-TF-1: AWS Security Group open egress
  # Required for RDS and Redis to communicate with EKS cluster
  - SNYK-CC-TF-1:
    - '*main.tf':
        reason: 'Egress to 0.0.0.0/0 required for RDS/Redis in private subnets'
        expires: '2025-08-24T00:00:00.000Z'

  # Hardcoded passwords in template files
  # These are intentionally placeholders
  - SNYK-CC-K8S-3:
    - '*secrets.yaml':
        reason: 'Template file with placeholder passwords - must be configured before deployment'
        expires: '2025-08-24T00:00:00.000Z'
    - '*postgres.yaml':
        reason: 'Default password placeholder - must be changed in production'
        expires: '2025-08-24T00:00:00.000Z'
    - '*variables.tf':
        reason: 'Terraform variables with secure random password generation'
        expires: '2025-08-24T00:00:00.000Z'

patch: {}
