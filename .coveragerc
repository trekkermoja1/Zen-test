[run]
branch = True
source = 
    tools
    modules
    core
    agents
    autonomous
    database
    risk_engine
    safety
    memory
    utils
    api
omit = 
    # Tests
    tests/*
    test_*.py
    *_test.py
    
    # Virtual environments
    venv/*
    .venv/*
    env/*
    
    # Build artifacts
    build/*
    dist/*
    *.egg-info/*
    
    # Documentation
    docs/*
    
    # Frontend (separate coverage)
    web_ui/*
    gui/*
    dashboard/*
    
    # Examples
    examples/*
    
    # Scripts
    scripts/*

parallel = False

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    except ImportError
    except ModuleNotFoundError
    raise ImportError
    pass
    ^\s*\.\.\.$
    if TYPE_CHECKING:
    @abstractmethod

show_missing = True
precision = 1
skip_covered = False

[html]
directory = htmlcov
