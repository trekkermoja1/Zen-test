[run]
branch = True
# NUR die Module tracken die wir auch testen
source = 
    tools/ffuf_integration_enhanced.py
    tools/whatweb_integration.py
    tools/wafw00f_integration.py
    tools/subfinder_integration.py
    tools/httpx_integration.py
    tools/nikto_integration.py
    tools/sherlock_integration.py
    tools/ignorant_integration.py
    tools/tshark_integration.py
    tools/amass_integration.py
    tools/masscan_integration.py
    tools/gobuster_integration.py
    tools/nmap_integration.py
    tools/tool_registry.py
    tools/tool_caller.py
    modules/enhanced_recon.py
    modules/osint_super.py
    modules/super_scanner.py
    core/orchestrator.py
    database/models.py
    agents/agent_base.py
    agents/agent_orchestrator.py
    autonomous/agent_loop.py
    autonomous/exploit_validator.py
omit = 
    tests/*
    test_*.py
    venv/*
    .venv/*
    build/*
    dist/*

parallel = False

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    except ImportError
    except ModuleNotFoundError
    raise ImportError
    pass

show_missing = True
precision = 1
skip_covered = False

[html]
directory = htmlcov
