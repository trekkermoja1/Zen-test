// Jenkins Pipeline for Zen AI Pentest
// Add this as Jenkinsfile in your repository

pipeline {
    agent any

    environment {
        ZEN_TARGET = 'http://target-application'
        ZEN_SCAN_TYPE = 'standard'
        ZEN_SAFETY_LEVEL = 'non_destructive'
        ZEN_FAIL_ON = 'high'
    }

    stages {
        stage('Setup') {
            steps {
                sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install --upgrade pip
                    pip install zen-ai-pentest
                '''
            }
        }

        stage('Security Scan') {
            steps {
                sh '''
                    . venv/bin/activate
                    zen-ai-pentest scan \
                        --target "${ZEN_TARGET}" \
                        --scan-type "${ZEN_SCAN_TYPE}" \
                        --safety-level "${ZEN_SAFETY_LEVEL}" \
                        --output zen-results.json
                '''
            }
        }

        stage('Parse Results') {
            steps {
                script {
                    def results = readJSON file: 'zen-results.json'

                    env.CRITICAL_COUNT = results.critical_findings ?: 0
                    env.HIGH_COUNT = results.high_findings ?: 0
                    env.MEDIUM_COUNT = results.medium_findings ?: 0
                    env.LOW_COUNT = results.low_findings ?: 0
                    env.TOTAL_COUNT = results.total_findings ?: 0

                    echo "Findings: Critical=${env.CRITICAL_COUNT}, High=${env.HIGH_COUNT}, Medium=${env.MEDIUM_COUNT}, Low=${env.LOW_COUNT}"
                }
            }
        }

        stage('Archive Results') {
            steps {
                archiveArtifacts artifacts: 'zen-results.*', allowEmptyArchive: true
                publishHTML([
                    allowMissing: false,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: '.',
                    reportFiles: 'zen-results.html',
                    reportName: 'Zen AI Security Report'
                ])
            }
        }
    }

    post {
        always {
            script {
                // Check fail condition
                def failOn = env.ZEN_FAIL_ON
                def shouldFail = false

                switch(failOn) {
                    case 'critical':
                        shouldFail = env.CRITICAL_COUNT.toInteger() > 0
                        break
                    case 'high':
                        shouldFail = env.CRITICAL_COUNT.toInteger() > 0 || env.HIGH_COUNT.toInteger() > 0
                        break
                    case 'medium':
                        shouldFail = env.CRITICAL_COUNT.toInteger() > 0 || env.HIGH_COUNT.toInteger() > 0 || env.MEDIUM_COUNT.toInteger() > 0
                        break
                }

                if (shouldFail) {
                    currentBuild.result = 'FAILURE'
                    error("Security scan found ${failOn} or higher severity issues!")
                }
            }
        }

        failure {
            emailext (
                subject: "Security Scan Failed: \${env.JOB_NAME} - \${env.BUILD_NUMBER}",
                body: "Critical or high severity vulnerabilities found. Check the report.",
                to: "\${env.CHANGE_AUTHOR_EMAIL ?: env.DEFAULT_RECIPIENTS}"
            )
        }
    }
}
