# =============================================================================
# Zen AI Pentest - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# SECURITY - CRITICAL: Change these in production!
# =============================================================================

# JWT Secret Key - Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin Credentials - CHANGE THESE!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# Database
DATABASE_URL=sqlite:///./zen_ai_pentest.db
DATABASE_SECRET_KEY=your-database-secret-key

# =============================================================================
# API Configuration
# =============================================================================

# CORS - Allowed origins (comma-separated)
# Production: Use specific domains only
# Example: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# API Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=10

# =============================================================================
# Docker / Container
# =============================================================================

# Docker Security
DOCKER_NON_ROOT_USER=zenuser
DOCKER_USER_ID=1000
DOCKER_GROUP_ID=1000

# =============================================================================
# External Services (Optional)
# =============================================================================

# LLM API Keys (if using external LLM providers)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-...

# SIEM Integration
# SPLUNK_HEC_URL=https://your-splunk:8088
# SPLUNK_HEC_TOKEN=your-hec-token
# ELASTICSEARCH_URL=https://your-elastic:9200

# Notification Webhooks
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable features
ENABLE_MOCK_SIEM=true
ENABLE_AUTONOMOUS_MODE=true
ENABLE_WEBSOCKET=true

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=INFO
LOG_FILE=logs/zen_ai_pentest.log
