# Zen-AI-Pentest Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zen_pentest
# For Docker:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/zen_pentest

# =============================================================================
# SECURITY
# =============================================================================
# Change this in production! Generate with: openssl rand -hex 32
SECRET_KEY=change-this-secret-key-in-production
JWT_EXPIRATION=3600

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# =============================================================================
# REDIS (for caching and background tasks)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
# For Docker:
# REDIS_URL=redis://redis:6379/0

# =============================================================================
# NOTIFICATIONS - SLACK
# =============================================================================
# Get webhook URL from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#security-alerts

# =============================================================================
# NOTIFICATIONS - EMAIL (SMTP)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@zen-pentest.local

# =============================================================================
# CLOUD PROVIDERS - AWS
# =============================================================================
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1

# =============================================================================
# CLOUD PROVIDERS - AZURE
# =============================================================================
AZURE_SUBSCRIPTION_ID=...
AZURE_TENANT_ID=...
AZURE_CLIENT_ID=...
AZURE_CLIENT_SECRET=...

# =============================================================================
# CLOUD PROVIDERS - GOOGLE CLOUD
# =============================================================================
GCP_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# =============================================================================
# VIRTUALBOX
# =============================================================================
VBOX_USER_HOME=/home/user/VirtualBox VMs

# =============================================================================
# TOOL CONFIGURATION
# =============================================================================
# BurpSuite Enterprise
BURP_API_URL=http://localhost:8080
BURP_API_KEY=your-api-key

# Metasploit RPC
MSF_RPC_HOST=127.0.0.1
MSF_RPC_PORT=55553
MSF_RPC_USER=msf
MSF_RPC_PASS=your-password

# =============================================================================
# LLM CONFIGURATION
# =============================================================================
# OpenAI (default)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Or Azure OpenAI
# AZURE_OPENAI_KEY=...
# AZURE_OPENAI_ENDPOINT=https://....openai.azure.com/

# Or other providers (OpenRouter, etc.)
# OPENROUTER_API_KEY=...

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_VM_ISOLATION=true
ENABLE_AUTO_CLEANUP=true
AUTO_SHUTDOWN_HOURS=4
MAX_SCAN_DURATION=3600

# =============================================================================
# MONITORING
# =============================================================================
SENTRY_DSN=
LOG_LEVEL=INFO

# =============================================================================
# DEVELOPMENT
# =============================================================================
# Only for development!
RELOAD=true
TESTING=false
