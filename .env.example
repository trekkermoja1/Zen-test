# =============================================================================
# Zen AI Pentest - Environment Configuration Example
# =============================================================================
# Copy this file to .env and customize for your environment
# =============================================================================

# =============================================================================
# Core Configuration
# =============================================================================
ZEN_AI_ENV=development
ZEN_AI_LOG_LEVEL=INFO

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
# Generate secure password: openssl rand -base64 32
DB_PASSWORD=change-this-to-secure-password
DB_PORT=5432

# =============================================================================
# Redis Configuration (Cache & Message Queue)
# =============================================================================
REDIS_PASSWORD=change-this-to-secure-password
REDIS_PORT=6379

# =============================================================================
# API Keys (Optional - for LLM backends)
# =============================================================================
# OpenRouter API Key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# =============================================================================
# Proton VPN Configuration (Optional)
# =============================================================================
PROTONVPN_USERNAME=
PROTONVPN_PASSWORD=
# WireGuard private key (optional, for wireguard connection)
WIREGUARD_PRIVATE_KEY=
# Default server (CH, NL, SE, IS, etc.)
PROTONVPN_SERVER=CH

# =============================================================================
# Port Configuration
# =============================================================================
# Main API port
ZEN_API_PORT=8080

# Web dashboard port (future)
ZEN_WEB_PORT=3000

# Database port (internal only recommended)
DB_PORT=5432

# Redis port (internal only recommended)
REDIS_PORT=6379

# Kibana port (when using monitoring profile)
KIBANA_PORT=5601

# Traefik dashboard port (when using proxy profile)
TRAEFIK_DASHBOARD_PORT=8080

# Elasticsearch port (when using monitoring profile)
ES_PORT=9200

# =============================================================================
# Scaling Configuration
# =============================================================================
# Number of worker replicas
WORKER_REPLICAS=1

# Worker scale factor
WORKER_SCALE=1

# =============================================================================
# SSL/TLS Configuration (Production)
# =============================================================================
# Email for Let's Encrypt notifications
ACME_EMAIL=admin@example.com

# =============================================================================
# Security Configuration
# =============================================================================
# Enable kill switch for VPN (1=enabled, 0=disabled)
VPN_KILL_SWITCH=1

# Debug mode (true/false) - NEVER enable in production!
DEBUG=false
