# 🧠 Zen-AI Pentest - API Konfiguration
# Kopiere diese Datei zu .env und füge deine Keys ein
# WICHTIG: .env niemals committen!

# Kimi AI (Standard)
export KIMI_API_KEY=""
export DEFAULT_BACKEND="kimi"
export DEFAULT_MODEL="kimi-k2.5"

# Alternative Backends (optional)
