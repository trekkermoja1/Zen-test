{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Python: Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/test_working_final.py",
        "-v"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Python: Tests with Coverage",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/test_working_final.py",
        "--cov=core",
        "--cov-report=xml",
        "-v"
      ],
      "console": "integratedTerminal"
    }
  ]
}
